    <<set _touchreq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_CROSSOVER_TOUCH_EXHIB, $pc)>>
    <<set _playreq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_CROSSOVER_PLAY_EXHIB, $pc)>>
    <<set _pacts to setup.Tanning.get_partner_menu_actions(_sub, "tanning")>>
    <<if _pacts.length gt 0>>
        <span class="small">Adjust <<anonorfirstname _sub>> for <<anonorfirstname _w>>:</span>
