:: TanExhibWidgets [widget nobr]

<<widget "tanswimsuitchangeflash">>
    <<if $tanswimchangemsg>>
        <br><br>
        <<= $tanswimchangemsg>>
        <<unset $tanswimchangemsg>>
    <</if>>
<</widget>>

<<widget "tanswimsuitchangemenu">>
    <<if setup.Tanning.get_tanning_site() is "UniMall" and !$pc.wearing_some_swimwear() and setup.Tanning.can_offer_swimsuit_change($pc)>>
    <<set _methods to setup.Tanning.get_swimsuit_change_methods($pc)>>
    <<if _methods.length gt 0>>
    <br><br>
    You aren't dressed for tanning in swimwear yet. Change first, then pick what to wear:
    <br>
    <<for _m range _methods>>
        <<capture _m>>
            <<set _swimchglabel to _m.label>>
            <<set _swimchgpass to _m.passage>>
            <<if _m.enabled>>
                    <<link _swimchglabel _swimchgpass>>
                        <<set $tanswimchangetarget to setup.Tanning.get_swim_change_tan_menu()>>
                        <<if setup.Tanning.TANNING_SITES[$location]>>
                            <<set $tanninglocation to $location>>
                        <<elseif $tanninglocation>>
                            <<set $tanninglocation to $tanninglocation>>
                        <</if>>
                        <<set _fx to setup.Tanning.apply_swimsuit_change($pc, _m.id)>>
                        <<set $tanswimchangemsg to _fx.msg>>
                        <<if _fx.attention>><<dalterneed Attention _fx.attention true>><</if>>
                        <<if _fx.humiliation>><<dalterneed Humiliation _fx.humiliation true>><</if>>
                        <<if _fx.arousal>><<dalterneed Arousal _fx.arousal true>><</if>>
                        <<if _fx.exhib>><<raiseskill Exhibitionism 1>><</if>>
                        <<advtime _m.minutes>>
                    <</link>> <<dtime _m.minutes>>
                    <<if _m.exhib_req>><<skill Exhibitionism _m.exhib_req>><</if>>
                    <<if _m.hint>><span class="small"> — <<print _m.hint>></span><</if>>
                    <br>
            <<else>>
                <span class="disabled-action"><<print _m.label>><<if _m.disabled_hint>> — <<print _m.disabled_hint>><</if>></span>
                <<if _m.exhib_req>><<skill Exhibitionism _m.exhib_req>><</if>>
                <br>
            <</if>>
        <</capture>>
    <</for>>
    <<link "Pick a swimsuit from your closet" TanSwimWardrobe>>
        <<set $tanswimchangetarget to setup.Tanning.get_swim_change_tan_menu()>>
        <<run setup.Tanning.begin_swimsuit_picker($pc)>>
        <<set $tanswimchangemsg to "You take a moment to decide what to wear.">>
    <</link>>
    <br>
    <</if>>
    <</if>>
<</widget>>

<<widget "tandexhibposemenu">>
    <<if setup.Tanning.can_exhibition_tan($pc)>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<if !$tanpose>>
        <div class="tan-exhib-pose">
            <br>How do you want to lay out?
            <br><br>
            <<link "Lay on your back" _tanret>>
                <<set $tanpose to "back">>
                <<run setup.Tanning.save_displacement_snapshot($pc)>>
            <</link>> <<skill Exhibitionism setup.Tanning.EXHIB_TANNING_MIN>>
            <br>
            <<link "Lay on your stomach" _tanret>>
                <<set $tanpose to "stomach">>
                <<run setup.Tanning.save_displacement_snapshot($pc)>>
            <</link>> <<skill Exhibitionism setup.Tanning.EXHIB_TANNING_MIN>>
            <br>
        </div>
    <<else>>
        <<print setup.Tanning.pose_narration($tanpose, $pc)>>
        <br><br>
        <<if $tanpose is "back">>
            <<link "Switch to laying on your stomach" _tanret>>
                <<set $tanpose to "stomach">>
            <</link>>
        <<else>>
            <<link "Switch to laying on your back" _tanret>>
                <<set $tanpose to "back">>
            <</link>>
        <</if>>
        <br><br>
        <<tandexhibpasstime>>
        <<tantanphonemenu>>
    <</if>>
    <</if>>
<</widget>>

<<widget "tantanphonemenu">>
    <<if setup.Tanning.can_use_phone_while_tanning($pc)>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <div class="tan-exhib-phone-entry">
        <<if setup.Tanning.pc_has_tan_phone($pc)>>
            <<link "Grab your phone" TanPhoneMenu>>
                <<run setup.Tanning.ensure_tan_phone_context($pc)>>
                <<advtime _tq Attention>>
            <</link>> <<dtime _tq>>
        <<else>>
            <span class="disabled-action">Your backpack is here, but you don't have a phone in it right now.</span>
        <</if>>
    </div>
    <</if>>
<</widget>>

<<widget "tantanphoneoptions">>
    <<if $tanpose>>
    <<if !setup.Tanning.pc_has_tan_phone($pc)>>
        <div class="tan-exhib-flavor">Your backpack is here, but you don't have a phone in it right now.</div>
    <<else>>
    <<set _phoneRet to setup.Tanning.get_tan_phone_passage()>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<set _contacts to setup.Tanning.get_tan_phone_contacts($pc)>>
    <<set _inviteact to setup.Tanning.get_tan_invite_activity()>>
    <div class="tan-exhib-legend">Your backpack stays beside the towel — phone, toys, and whatever else you brought are still within reach.</div>
    <div class="tan-exhib-action">
        <<capture _phoneRet,_tq>>
            <<link "Open phone" _phoneRet>>
                <<run setup.Tanning.open_tan_phone("PhoneMain")>>
                <<advtime _tq Attention>>
            <</link>> <<dtime _tq>>
        <</capture>>
    </div>
    <div class="tan-exhib-action">
        <<capture _phoneRet,_tq>>
            <<link "Text someone" _phoneRet>>
                <<run setup.Tanning.open_tan_phone("PhoneContacts")>>
                <<advtime _tq Attention>>
            <</link>> <<dtime _tq>>
        <</capture>>
    </div>
    <<tantanphoneelkbookmenu>>
        <<if _contacts.length gt 0>>
            <<tantanphoneselfiemenu>>
        <</if>>
        <<if _contacts.length gt 0>>
            <<tantanphoneinvitemenu>>
        <</if>>
        <div class="tan-exhib-adjust-title">Amateur Porn Town</div>
        <<if setup.Tanning.can_post_tan_video($pc)>>
            <<if $pc.skillleveled("Exhibitionism", setup.Tanning.TAN_VIDEO_EXHIB)>>
                <<capture _phoneRet,_tq>>
                    <<link "Record a tanning video" _phoneRet>>
                        <<set _vidfx to setup.Tanning.prepare_tan_exhibition_video($pc)>>
                        <<set $tandisplacemsg to _vidfx.msg>>
                        <<if _vidfx.ok>>
                            <<raiseskill Exhibitionism 1>>
                            <<advtime 10 Attention>>
                            <<goto AmateurPornTownEdit>>
                        <</if>>
                    <</link>> · Exhib <<print setup.Tanning.TAN_VIDEO_EXHIB>> <<dtime 10>>
                <</capture>>
            <<else>>
                <span class="disabled-action">Record a tanning video · Need Exhib <<print setup.Tanning.TAN_VIDEO_EXHIB>></span>
            <</if>>
        <<else>>
            <span class="disabled-action">Record a tanning video · Register on Amateur Porn Town first (phone → Internet)</span>
        <</if>>
    <</if>>
    <</if>>
<</widget>>

<<widget "tantanphonesetselfiemenu">>
    <<set $phoneselfiemenu to setup.Tanning.build_tan_selfie_menu($pc)>>
<</widget>>

<<widget "tantanphoneselfieconvo">>
    <<if $phoneselfiesession>>
    <<set _s to $phoneselfiesession>>
    <<set _selfie to _s.pendingEffects or _s.selfie>>
    <<set _p to _s.target>>
    <<set _phoneRet to setup.Tanning.get_tan_phone_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<set _underwear to _selfie[2] or []>>
    <<set _naked to _selfie[3] or []>>
    <<set _inccomposure to _selfie[4].inccomposure>>

    <div class="tan-exhib-adjust-title"><<anonorfullname _p>></div>
    <<if _s.photoCount is 1>>
        <div class="tan-exhib-flavor">You hit send and off it goes.</div>
    <</if>>

    <<if !_s.effectsShown>>
        <<run setup.Tanning.mark_selfie_effects_shown()>>
        <<if _naked.length gt 0>>
            <<= setup.Events.exhibitionism(_naked, "naked", "photo", true, [_p], {nocomposure: !_inccomposure}).dalterneed>>
        <<elseif _underwear.length gt 0>>
            <<= setup.Events.exhibitionism(_underwear, "underwear", "photo", true, [_p], {nocomposure: !_inccomposure}).dalterneed>>
        <</if>>
        <<if _s.photoCount is 1 and _p and _selfie[4].prevattitude>>
            <<for _att range ["friendship", "lust", "romance"]>>
                <<set _prev to _selfie[4].prevattitude[_att] or 0>>
                <<set _pdata to setup.people.get_person(_p)>>
                <<if _pdata and _pdata.attitude>>
                    <<set _current to _pdata.attitude[_att] or 0>>
                <<else>>
                    <<set _current to 0>>
                <</if>>
                <<if _prev isnot _current>>
                    <<set _label to _att.toUpperFirst()>>
                    <<set _diff to _current - _prev>>
                    <<dalterneed _label _diff>>
                <</if>>
            <</for>>
        <</if>>
        <br>
    <</if>>

    <div class="tan-exhib-selfie-convo">
        <<for _line range _s.lines>>
            <<if _line.from is "narrate">>
                <div class="tan-exhib-flavor"><<= _line.text>></div>
            <<elseif _line.from is "photo">>
                <div class="tan-selfie-bubble tan-selfie-bubble-photo">
                    <<if _line.image>><<= _line.image>><br><</if>>
                    <span class="tan-selfie-photo-label"><<= _line.label>></span>
                </div>
            <<elseif _line.from is "pc">>
                <div class="tan-selfie-bubble tan-selfie-bubble-pc"><<= _line.text>></div>
            <<elseif _line.from is "npc">>
                <div class="tan-selfie-bubble tan-selfie-bubble-npc"><<= _line.text>></div>
            <</if>>
        <</for>>
    </div>

    <<if _s.awaitingSelfiePick>>
        <div class="tan-exhib-legend"><<= _s.selfiePickPrompt>></div>
        <<set $phoneselfiemenu to setup.Tanning.build_selfie_menu_for_convo($pc, _s)>>
        <<if $phoneselfiemenu.length is 0>>
            <div class="tan-exhib-flavor">Nothing bolder to send from here right now.</div>
            <div class="tan-exhib-phone-contact">
                <<link "Never mind" _phoneRet>>
                    <<run setup.Tanning.cancel_convo_selfie_pick()>>
                <</link>>
            </div>
        <<else>>
            <div class="tan-exhib-phone-contacts">
                <<for _pick range $phoneselfiemenu>>
                    <<set _pexhib to _pick[1]>>
                    <<capture _pick,_pexhib,_phoneRet,_tq>>
                        <div class="tan-exhib-phone-contact">
                            <<link _pick[0] _phoneRet>>
                                <<set $tanphoneselfiepick to _pick>>
                                <<run setup.Tanning.send_convo_followup_selfie()>>
                                <<advtime _tq Attention>>
                            <</link>>
                            <<if _pexhib gt 0>> · Exhib <<print _pexhib>> <<skill Disinhibition 3>><</if>> <<dtime _tq>>
                        </div>
                    <</capture>>
                <</for>>
            </div>
            <div class="tan-exhib-phone-contact">
                <<link "Never mind" _phoneRet>>
                    <<run setup.Tanning.cancel_convo_selfie_pick()>>
                <</link>>
            </div>
        <</if>>
        <<unset $phoneselfiemenu>>
    <<elseif _s.awaitingPc and !_s.done>>
        <div class="tan-exhib-legend">Your reply:</div>
        <div class="tan-exhib-phone-contacts">
            <<set _options to setup.Tanning.get_selfie_pc_replies(_s)>>
            <<for _opt range _options>>
                <<capture _opt,_phoneRet,_tq>>
                    <div class="tan-exhib-phone-contact">
                        <<link _opt.text _phoneRet>>
                            <<set $tanselfiereplypick to _opt.id>>
                            <<run setup.Tanning.apply_selfie_pc_reply()>>
                            <<advtime _tq Attention>>
                        <</link>>
                    </div>
                <</capture>>
            <</for>>
        </div>
    <<elseif _s.done>>
        <<if _s.inviteResolved>>
            <br>
            <div class="tan-exhib-flavor"><<if $taninvitemsg>><<= $taninvitemsg>><<else>>The invite is out — now you wait and see.<</if>></div>
        <</if>>
        <div class="tan-exhib-phone-contact">
            <<link "Done texting" _phoneRet>>
                <<run setup.Tanning.finish_selfie_convo()>>
                <<advtime 5 Attention>>
            <</link>> <<dtime 5>>
        </div>
    <<else>>
        <<set _discover to _selfie[4].discoverchance>>
        <<if _discover and $peopleatlocation.length gt 0>>
            <<if $peopleatlocation gte 5>><<set _discover += 0.4>><<elseif $peopleatlocation gte 3>><<set _discover += 0.2>><</if>>
            <<set _p2 to setup.Events.pick_person({attitudes: ["random"], specialok: true, exclude: [_p]})>>
            <<if _p2 isnot null and State.random() lte _discover>>
                <br>
                <div class="tan-exhib-flavor">You look around as you're fixing your clothing, and... oops. You're pretty sure <<anonorfullname _p2>> noticed what you were doing.</div>
                <<if _naked.length gt 0>>
                    <<= setup.Events.exhibitionism(_naked, "naked", "in person", false, [_p2], {nocomposure: !_inccomposure}).dalterneed>>
                <<elseif _underwear.length gt 0>>
                    <<= setup.Events.exhibitionism(_underwear, "underwear", "in person", false, [_p2], {nocomposure: !_inccomposure}).dalterneed>>
                <</if>>
            <</if>>
        <</if>>
        <div class="tan-exhib-phone-contact">
            <<link "Done texting" _phoneRet>>
                <<run setup.Tanning.finish_selfie_convo()>>
                <<advtime 5 Attention>>
            <</link>> <<dtime 5>>
        </div>
    <</if>>
    <</if>>
<</widget>>

<<widget "phoneselfieconvomenu">>
    <<if $phoneselfiesession>>
    <<set _s to $phoneselfiesession>>
    <<set _selfie to _s.pendingEffects or _s.selfie>>
    <<set _p to _s.target>>
    <<set _underwear to _selfie[2] or []>>
    <<set _naked to _selfie[3] or []>>
    <<set _inccomposure to _selfie[4].inccomposure>>

    <<if !_s.effectsShown>>
        <<run setup.Tanning.mark_selfie_effects_shown()>>
        <<if _naked.length gt 0>>
            <<= setup.Events.exhibitionism(_naked, "naked", "photo", true, [_p], {nocomposure: !_inccomposure}).dalterneed>>
        <<elseif _underwear.length gt 0>>
            <<= setup.Events.exhibitionism(_underwear, "underwear", "photo", true, [_p], {nocomposure: !_inccomposure}).dalterneed>>
        <</if>>
        <<if _s.photoCount is 1 and _p and _selfie[4].prevattitude>>
            <<for _att range ["friendship", "lust", "romance"]>>
                <<set _prev to _selfie[4].prevattitude[_att] or 0>>
                <<set _pdata to setup.people.get_person(_p)>>
                <<if _pdata and _pdata.attitude>>
                    <<set _current to _pdata.attitude[_att] or 0>>
                <<else>>
                    <<set _current to 0>>
                <</if>>
                <<if _prev isnot _current>>
                    <<set _label to _att.toUpperFirst()>>
                    <<set _diff to _current - _prev>>
                    <<dalterneed _label _diff>>
                <</if>>
            <</for>>
        <</if>>
    <</if>>

    <<if _s.awaitingSelfiePick>>
        <div class="tan-exhib-legend"><<= _s.selfiePickPrompt>></div>
        <<set $phoneselfiemenu to setup.Tanning.build_selfie_menu_for_convo($pc, _s)>>
        <<if $phoneselfiemenu.length is 0>>
            <<phonelink "Never mind">>
                <<run setup.Tanning.cancel_convo_selfie_pick()>>
                <<phonetextrefresh>>
            <</phonelink>>
        <<else>>
            <<for _pick range $phoneselfiemenu>>
                <<set _pexhib to _pick[1]>>
                <<capture _pick,_pexhib>>
                    <<phonelink _pick[0]>>
                        <<set $tanphoneselfiepick to _pick>>
                        <<run setup.Tanning.send_convo_followup_selfie()>>
                        <<advtime 5 Attention>>
                        <<phonetextrefresh>>
                    <</phonelink>> <<if _pexhib gt 0>> · Exhib <<print _pexhib>> <<skill Disinhibition 3>><</if>> <<dtime 5>>
                    <br>
                <</capture>>
            <</for>>
            <<phonelink "Never mind">>
                <<run setup.Tanning.cancel_convo_selfie_pick()>>
                <<phonetextrefresh>>
            <</phonelink>>
        <</if>>
        <<unset $phoneselfiemenu>>
    <<elseif _s.awaitingPc and !_s.done>>
        <<set _options to setup.Tanning.get_selfie_pc_replies(_s)>>
        <<for _opt range _options>>
            <<capture _opt>>
                <<phonelink _opt.text>>
                    <<set $tanselfiereplypick to _opt.id>>
                    <<run setup.Tanning.apply_selfie_pc_reply()>>
                    <<advtime 5 Attention>>
                    <<phonetextrefresh>>
                <</phonelink>> <<dtime 5>>
                <br>
            <</capture>>
        <</for>>
    <<else>>
        <<phonelink "Done texting">>
            <<run setup.Tanning.finish_selfie_convo()>>
            <<advtime 5 Attention>>
            <<phonetextrefresh>>
        <</phonelink>> <<dtime 5>>
    <</if>>
    <</if>>
<</widget>>

<<widget "tantanelkbookreplyloop">>
    <<if $phoneselfiesent>>
    <<set _selfie to $phoneselfiesent>>
    <<set _replychance to (_selfie[3].length gt 0 || _selfie[2].length gt 0) ? 0.667 : 0.25>>
    <<set _anyreplies to false>>
    <<for _student range _people>>
        <<if _anyreplies and State.random() lte _replychance>>
            <<continue>>
        <<else>>
            <<set _anyreplies to true>>
        <</if>>
        <<set _msg to setup.Tanning.pick_tan_elkbook_reply(_student, _selfie)>>
        <div class="elkbook-container tan-exhib-elkbook-reply">
            <span class="elkbook-name">
                <<known _student>>
                    <<viewperson _student>><<dfullname _student>><</viewperson>>
                <<unknown>>
                    <<dfullname _student>>
                <</known>>
            </span><br>
            <span class="elkbook-text"><<= _msg>></span>
        </div>
    <</for>>
    <</if>>
<</widget>>

<<widget "tantanphoneelkbookmenu">>
    <<set _phoneRet to setup.Tanning.get_tan_phone_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<if $elkbook and $elkbook.lastpost and $gameday - $elkbook.lastpost lt 1>>
        <div class="tan-exhib-adjust-title">Post to Elkbook</div>
        <div class="tan-exhib-flavor">You've already posted to Elkbook today.</div>
    <<else>>
    <div class="tan-exhib-adjust-title">Post to Elkbook</div>
    <<if !$tanphoneelkbookopen>>
        <div class="tan-exhib-phone-contact">
            <<link "Post to Elkbook" _phoneRet>>
                <<set $tanphoneelkbookopen to true>>
                <<unset $tanphoneselfiecontact>>
            <</link>>
        </div>
    <<else>>
        <div class="tan-exhib-legend">Snap a tanning selfie for today's timeline — onlookers might notice.</div>
        <<tantanphonesetselfiemenu>>
        <div class="tan-exhib-phone-contacts">
            <<for _selfie range $phoneselfiemenu>>
                <<set _exhib to _selfie[1]>>
                <<if $pc.skillleveled("Exhibitionism", _exhib) and (_exhib is 0 or $pc.skillleveled("Disinhibition", 3))>>
                    <<capture _selfie,_exhib,_phoneRet,_tq>>
                        <div class="tan-exhib-phone-contact">
                            <<link _selfie[0]>>
                                <<run setup.Tanning.set_tan_phone_return()>>
                                <<set $phoneselfiesent to setup.Tanning.stage_tan_elkbook_selfie_send(_selfie)>>
                                <<raiseskill Photography 2>>
                                <<advtime _tq Attention>>
                                <<egoto TanElkbookSelfie>>
                            <</link>>
                            <<if _exhib gt 0>> · Exhib <<print _exhib>> <<skill Disinhibition 3>><</if>> <<dtime _tq>>
                        </div>
                    <</capture>>
                <</if>>
            <</for>>
        </div>
        <<unset $phoneselfiemenu>>
        <div class="tan-exhib-phone-contact">
            <<link "« Back" _phoneRet>>
                <<unset $tanphoneelkbookopen>>
            <</link>>
        </div>
    <</if>>
    <</if>>
<</widget>>

<<widget "tantanphoneselfiemenu">>
    <<set _phoneRet to setup.Tanning.get_tan_phone_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<set _contacts to setup.Tanning.get_tan_phone_contacts($pc)>>
    <<if _contacts.length gt 0>>
    <div class="tan-exhib-adjust-title">Send a selfie</div>
    <<if !$tanphoneselfiecontact>>
        <div class="tan-exhib-legend">Text a pic to a friend, lover, or booty call — onlookers might catch you posing.</div>
        <div class="tan-exhib-phone-contacts">
            <<for _c range _contacts>>
                <<capture _c,_phoneRet>>
                    <div class="tan-exhib-phone-contact">
                        <<link _c.label _phoneRet>>
                            <<set $tanphoneselfiecontact to _c.name>>
                            <<unset $tanphoneelkbookopen>>
                        <</link>>
                    </div>
                <</capture>>
            <</for>>
        </div>
    <<else>>
        <<set _picklabel to setup.Tanning.menu_npc_label($tanphoneselfiecontact)>>
        <div class="tan-exhib-legend"><<= _picklabel >> — pick a shot to send.</div>
        <<tantanphonesetselfiemenu>>
        <div class="tan-exhib-phone-contacts">
            <<for _selfie range $phoneselfiemenu>>
                <<set _exhib to _selfie[1]>>
                <<if $pc.skillleveled("Exhibitionism", _exhib) and (_exhib is 0 or $pc.skillleveled("Disinhibition", 3))>>
                    <<capture _selfie,_exhib,_phoneRet,_tq>>
                        <div class="tan-exhib-phone-contact">
                            <<link _selfie[0] TanPhoneMenu>>
                                <<run setup.Tanning.set_tan_phone_return()>>
                                <<set $phoneselfiesent to setup.Tanning.begin_tan_phone_selfie_convo(_selfie, $tanphoneselfiecontact)>>
                                <<advtime _tq Attention>>
                            <</link>>
                            <<if _exhib gt 0>> · Exhib <<print _exhib>> <<skill Disinhibition 3>><</if>> <<dtime _tq>>
                        </div>
                    <</capture>>
                <</if>>
            <</for>>
        </div>
        <<unset $phoneselfiemenu>>
        <div class="tan-exhib-phone-contact">
            <<link "« Pick someone else" _phoneRet>>
                <<unset $tanphoneselfiecontact>>
            <</link>>
        </div>
    <</if>>
    <</if>>
<</widget>>

<<widget "tantanphoneinvitemenu">>
    <<set _phoneRet to setup.Tanning.get_tan_phone_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<set _contacts to setup.Tanning.get_tan_phone_contacts($pc)>>
    <<set _inviteact to setup.Tanning.get_tan_invite_activity()>>
    <<if _contacts.length gt 0>>
    <div class="tan-exhib-adjust-title">Invite someone</div>
    <div class="tan-exhib-legend">Ask someone to come <i>watch</i> you tan, or to <i>join</i> you on the towel if they're bold enough (exhibitionist, submissive, or under your control).</div>
    <div class="tan-exhib-phone-contacts">
        <<for _c range _contacts>>
            <<capture _c,_phoneRet,_tq,_inviteact>>
                <div class="tan-exhib-phone-contact">
                    <<link "Invite <<anonorfirstname _c.name>> to watch" _phoneRet>>
                        <<set _inv to setup.Tanning.quick_tan_invite(_c.name, "watch")>>
                        <<if _inv.ok and _inv.arrivalMsg>><<set $taninvitemsg to _inv.arrivalMsg>><<else>><<set $taninvitemsg to _inv.npcText>><</if>>
                        <<advtime _tq Attention>>
                    <</link>> <<dtime _tq>>
                </div>
                <<if setup.Tanning.can_invite_to_join_towel($pc, _c.name)>>
                <div class="tan-exhib-phone-contact">
                    <<link "Invite <<anonorfirstname _c.name>> to join your towel" _phoneRet>>
                        <<set _inv to setup.Tanning.quick_tan_invite(_c.name, "join")>>
                        <<if _inv.ok and _inv.arrivalMsg>><<set $taninvitemsg to _inv.arrivalMsg>><<else>><<set $taninvitemsg to _inv.npcText>><</if>>
                        <<advtime _tq Attention>>
                    <</link>> <<dtime _tq>>
                </div>
                <<else>>
                <div class="tan-exhib-phone-contact">
                    <span class="disabled-action">Invite <<anonorfirstname _c.name>> to join · not exhibitionist/sub enough</span>
                </div>
                <</if>>
                <div class="tan-exhib-phone-contact">
                    <<link "Text <<anonorfirstname _c.name>>..." _phoneRet>>
                        <<run setup.Tanning.open_tan_text_contact(_c.name)>>
                        <<set $tanphoneinvitehint to _inviteact>>
                        <<advtime _tq Attention>>
                    <</link>> <<dtime _tq>>
                </div>
            <</capture>>
        <</for>>
    </div>
    <</if>>
<</widget>>

<<widget "tandexhibpasstime">>
    <<if setup.Tanning.can_exhibition_tan($pc) and $tanpose>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <div class="tan-exhib-passtime">
        Pass time on your towel:
        <br>
        <<capture _tanret>>
            <<link "Continue tanning like this (15 min)" _tanret>>
                <<set _tanfx to setup.Tanning.apply_pass_time($pc, 15)>>
                <<set $tanpassmsg to _tanfx.passmsg>>
                <<if _tanfx.witness>>
                    <<set $tanwitness to _tanfx.witness>>
                <</if>>
                <<if _tanfx.extras and _tanfx.extras.length>>
                    <<set $tanwitnessextras to _tanfx.extras>>
                <</if>>
                <<if _tanfx.arousalGain>><<dalterneed Arousal _tanfx.arousalGain true>><</if>>
                <<if _tanfx.attentionGain>><<dalterneed Attention _tanfx.attentionGain true>><</if>>
                <<advtime 15 Relaxation>>
                <<run setup.Tanning.apply_session($pc, {session_minutes: 15})>>
            <</link>> <<dtime 15>>
            <br>
            <<link "Tan a while longer (30 min)" _tanret>>
                <<set _tanfx to setup.Tanning.apply_pass_time($pc, 30)>>
                <<set $tanpassmsg to _tanfx.passmsg>>
                <<if _tanfx.witness>>
                    <<set $tanwitness to _tanfx.witness>>
                <</if>>
                <<if _tanfx.extras and _tanfx.extras.length>>
                    <<set $tanwitnessextras to _tanfx.extras>>
                <</if>>
                <<if _tanfx.arousalGain>><<dalterneed Arousal _tanfx.arousalGain true>><</if>>
                <<if _tanfx.attentionGain>><<dalterneed Attention _tanfx.attentionGain true>><</if>>
                <<advtime 30 Relaxation>>
                <<run setup.Tanning.apply_session($pc, {session_minutes: 30})>>
            <</link>> <<dtime 30>>
            <br>
        <</capture>>
    </div>
    <</if>>
<</widget>>

<<widget "tandexhibmenuactions">>
    <<if setup.Tanning.can_exhibition_tan($pc) and $tanpose>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<set _tanacts to setup.Tanning.get_tan_menu_actions($pc, $tanpose)>>
    <<highlight "button-sexact-clothes">>
        <<for _j to 0; _j lt _tanacts.length; _j++>>
            <<set _tanact to _tanacts[_j]>>
            <<capture _tanact,_tanret>>
                <<if _tanact.exhib_req is 0 or $pc.skillleveled("Exhibitionism", _tanact.exhib_req)>>
                    <<capture _tanact>>
                        <div class="tan-exhib-action">
                            <<link _tanact.button _tanret>>
                                <<set $tandisplacemsg to setup.Tanning.displacement_narration($pc, _tanact)>>
                                <<run setup.Tanning.apply_tan_action($pc, _tanact)>>
                                <<run setup.Tanning.run_exhib_guest_self_adjustments()>>
                                <<set _tanfx to setup.Tanning.apply_witness_effects($pc, _tanact)>>
                                <<if _tanfx.witness>>
                                    <<set $tanwitness to _tanfx.witness>>
                                <</if>>
                                <<if _tanfx.extras and _tanfx.extras.length>>
                                    <<set $tanwitnessextras to _tanfx.extras>>
                                <</if>>
                                <<if _tanfx.arousalGain>><<dalterneed Arousal _tanfx.arousalGain true>><</if>>
                                <<if _tanfx.attentionGain>><<dalterneed Attention _tanfx.attentionGain true>><</if>>
                                <<if _tanact.exhib_req > 0 and (_tanact.visible_tags.length > 0 or (_tanact.kind is "legs" and _tanact.spread))>>
                                    <<raiseskill Exhibitionism 1>>
                                <</if>>
                                <<advtime _tq Relaxation Attention>>
                                <<run setup.Tanning.apply_session($pc, {session_minutes: _tq})>>
                            <</link>>
                            <<set _tanmeta to setup.Tanning.format_tan_action_meta(_tanact)>>
                            <<if _tanmeta>> · <<print _tanmeta>><</if>> <<dtime _tq>>
                        </div>
                    <</capture>>
                <<else>>
                    <div class="tan-exhib-action">
                        <span class="disabled-action"><<print _tanact.button>> · Need <<skill Exhibitionism _tanact.exhib_req>></span>
                    </div>
                <</if>>
            <</capture>>
        <</for>>
    <</highlight>>
    <</if>>
<</widget>>

<<widget "tandexhibmenu">>
    <<if setup.Tanning.can_exhibition_tan($pc) and $tanpose>>
    <<set _tanacts to setup.Tanning.get_tan_menu_actions($pc, $tanpose)>>
    <<if _tanacts.length is 0>>
        <div class="tan-exhib-adjust">
            <span class="notice">Nothing you can adjust further for this pose — at least, not without getting up.</span>
        </div>
    <<else>>
    <div class="tan-exhib-adjust">
        <div class="tan-exhib-adjust-title">Adjust your outfit while you tan</div>
        <div class="tan-exhib-legend">▲ Show more · ▼ Cover up — levels are step/max (e.g. 3/6). Notes after each action say what onlookers can see.</div>
        <div id="tanexhibact" class="tan-exhib-actions">
            <<if $tanexhibexpanded>>
                <<tandexhibmenuactions>>
            <<else>>
                <<button "Adjust clothing...">>
                    <<set $tanexhibexpanded to true>>
                    <<replace "#tanexhibact">><<tandexhibmenuactions>><</replace>>
                <</button>>
            <</if>>
        </div>
    </div>
    <</if>>
    <<tandexhibpartnermenu>>
    <<tandexhibguestmenu>>
    <</if>>
<</widget>>

<<widget "tandexhibpartnermenuactions">>
    <<set _partner to _partner or $tanpartnerexpanded>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<set _pacts to setup.Tanning.get_partner_menu_actions(_partner, "tanning")>>
    <<highlight "button-sexact-clothes">>
        <<for _j to 0; _j lt _pacts.length; _j++>>
            <<set _pact to _pacts[_j]>>
            <<capture _pact,_partner,_tanret,_tq>>
                <<if setup.Tanning.can_order_partner_action($pc, _partner, _pact)>>
                    <<capture _pact,_partner>>
                        <<set _plabel to setup.Tanning.partner_action_button_label(_partner, _pact)>>
                        <div class="tan-exhib-action">
                            <<link _plabel _tanret>>
                                <<set _pfx to setup.Tanning.apply_partner_tan_action($pc, _partner, _pact, "tanning")>>
                                <<if _pfx.msg>><<set $tandisplacemsg to _pfx.msg>><</if>>
                                <<advtime _tq Relaxation Attention>>
                            <</link>>
                            <<set _pmeta to setup.Tanning.format_tan_action_meta(_pact)>>
                            <<if _pmeta>> · <<print _pmeta>><</if>> <<dtime _tq>>
                        </div>
                    <</capture>>
                <<else>>
                    <div class="tan-exhib-action">
                        <span class="disabled-action"><<print setup.Tanning.partner_action_button_label(_partner, _pact)>><<if _pact.exhib_req gt 0>> · Need Exhib <<print _pact.exhib_req>> or higher Dominance<</if>></span>
                    </div>
                <</if>>
            <</capture>>
        <</for>>
    <</highlight>>
<</widget>>

<<widget "tandexhibguestmenu">>
    <<set _exhibguests to setup.Tanning.get_exhib_self_tan_guests($pc)>>
    <<if $tanpose and _exhibguests.length gt 0>>
    <<for _guest range _exhibguests>>
        <div class="tan-exhib-adjust tan-exhib-partner">
            <div class="tan-exhib-adjust-title"><<anonorfullname _guest>> on your towel</div>
            <div class="tan-exhib-legend"><<anonorfirstname _guest>> is choosing their own exposure — within their comfort (Exhib <<print setup.people.skill_level(_guest, "Exhibitionism")>>).</div>
        </div>
    <</for>>
    <</if>>
<</widget>>

<<widget "tandexhibpartnermenu">>
    <<set _controlled to setup.Tanning.get_controlled_tan_partners()>>
    <<if $tanpose and _controlled.length gt 0>>
    <<for _partner range _controlled>>
        <<set _pacts to setup.Tanning.get_partner_menu_actions(_partner, "tanning")>>
        <<if _pacts.length gt 0>>
        <div class="tan-exhib-adjust tan-exhib-partner">
            <div class="tan-exhib-adjust-title">Adjust <<anonorfullname _partner>>'s outfit</div>
            <div class="tan-exhib-legend">Your controlled partner will obey — if they're bold enough. ▲ Show more · ▼ Cover up.</div>
            <div class="tan-exhib-actions">
                <<if $tanpartnerexpanded and $tanpartnerexpanded is _partner>>
                    <<tandexhibpartnermenuactions>>
                    <br>
                    <<button "Done ordering <<anonorfirstname _partner>>">>
                        <<unset $tanpartnerexpanded>>
                        <<goto setup.Tanning.get_tan_passage()>>
                    <</button>>
                <<else>>
                    <<capture _partner>>
                    <<button "Tell <<anonorfirstname _partner>> to adjust clothing...">>
                        <<set $tanpartnerexpanded to _partner>>
                        <<goto setup.Tanning.get_tan_passage()>>
                    <</button>>
                    <</capture>>
                <</if>>
            </div>
        </div>
        <</if>>
    <</for>>
    <</if>>
<</widget>>

<<widget "outaboutexposureoffer">>
    <<if setup.Tanning.can_offer_out_exposure($pc)>>
    <br>
    <<if setup.Tanning.can_offer_pc_out_adjust($pc) and setup.Tanning.can_offer_partner_out_adjust($pc)>>
        <<link "Adjust clothing (yours or <<anonorfirstname $hangout.partner>>'s)" OutAboutExposure '👀'>>
            <<set $outaboutreturn to passage()>>
            <<advtime 1>>
        <</link>>
    <<elseif setup.Tanning.can_offer_pc_out_adjust($pc)>>
        <<link "Adjust your outfit" OutAboutExposure '👀'>>
            <<set $outaboutreturn to passage()>>
            <<advtime 1>>
        <</link>>
    <<else>>
        <<link "Adjust <<anonorfirstname $hangout.partner>>'s outfit" OutAboutExposure '👀'>>
            <<set $outaboutreturn to passage()>>
            <<advtime 1>>
        <</link>>
    <</if>> <<dtime 1>>
    <br>
    <</if>>
<</widget>>

<<widget "hangoutpartneradjustoffer">>
    <<outaboutexposureoffer>>
<</widget>>

<<widget "outaboutpcactions">>
    <<set _ret to setup.Tanning.out_about_adjust_return()>>
    <<set _pacts to setup.Tanning.get_pc_out_menu_actions($pc)>>
    <<highlight "button-sexact-clothes">>
        <<for _j to 0; _j lt _pacts.length; _j++>>
            <<set _pact to _pacts[_j]>>
            <<capture _pact,_ret>>
                <<if _pact.exhib_req is 0 or $pc.skillleveled("Exhibitionism", _pact.exhib_req)>>
                    <<capture _pact>>
                        <div class="tan-exhib-action">
                            <<link _pact.button _ret>>
                                <<set _pfx to setup.Tanning.apply_pc_out_action($pc, _pact)>>
                                <<if _pfx.msg>><<set $outaboutmsg to _pfx.msg>><</if>>
                                <<if _pfx.partnerMsg>><<set $outaboutpartnermsg to _pfx.partnerMsg>><</if>>
                                <<if _pact.exhib_req gt 0 and (_pact.visible_tags.length gt 0 or (_pact.kind is "legs" and _pact.spread))>>
                                    <<raiseskill Exhibitionism 1>>
                                <</if>>
                                <<advtime 5 Attention>>
                            <</link>>
                            <<set _pmeta to setup.Tanning.format_tan_action_meta(_pact)>>
                            <<if _pmeta>> · <<print _pmeta>><</if>> <<dtime 5>>
                        </div>
                    <</capture>>
                <<else>>
                    <div class="tan-exhib-action">
                        <span class="disabled-action"><<print _pact.button>> · Need <<skill Exhibitionism _pact.exhib_req>></span>
                    </div>
                <</if>>
            <</capture>>
        <</for>>
    <</highlight>>
<</widget>>

<<widget "outaboutpartneractions">>
    <<set _partner to $hangout.partner>>
    <<set _ret to setup.Tanning.out_about_adjust_return()>>
    <<set _pacts to setup.Tanning.get_partner_menu_actions(_partner, "out")>>
    <<highlight "button-sexact-clothes">>
        <<for _j to 0; _j lt _pacts.length; _j++>>
            <<set _pact to _pacts[_j]>>
            <<capture _pact,_partner,_ret>>
                <<if setup.Tanning.can_order_partner_action($pc, _partner, _pact)>>
                    <<capture _pact,_partner>>
                        <<set _plabel to setup.Tanning.partner_action_button_label(_partner, _pact)>>
                        <div class="tan-exhib-action">
                            <<link _plabel _ret>>
                                <<set _pfx to setup.Tanning.apply_partner_tan_action($pc, _partner, _pact, "out")>>
                                <<if _pfx.msg>><<set $outaboutmsg to _pfx.msg>><</if>>
                                <<advtime 5 Attention>>
                            <</link>>
                            <<set _pmeta to setup.Tanning.format_tan_action_meta(_pact)>>
                            <<if _pmeta>> · <<print _pmeta>><</if>> <<dtime 5>>
                        </div>
                    <</capture>>
                <<else>>
                    <div class="tan-exhib-action">
                        <span class="disabled-action"><<print setup.Tanning.partner_action_button_label(_partner, _pact)>><<if _pact.exhib_req gt 0>> · Won't go that far<</if>></span>
                    </div>
                <</if>>
            <</capture>>
        <</for>>
    <</highlight>>
<</widget>>

<<widget "hangoutpartneradjustactions">>
    <<outaboutpartneractions>>
<</widget>>

<<widget "tandexhibwitnessmenu">>
    <<if setup.Tanning.can_exhibition_tan($pc) and $tanpose>>
    <<set _witnesses to setup.Tanning.get_active_witness_choices($pc)>>
    <<if _witnesses.length gt 0>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <div class="tan-exhib-witnesses">
        <div class="tan-exhib-adjust-title">Onlookers</div>
        <div class="tan-exhib-legend">▲ Shift to show them more · ▼ Hide from them — hiding usually clears a glance, but bold watchers may take it as an invitation to move closer.</div>
        <<for _w range _witnesses>>
            <<capture _w,_tanret,_tq>>
                <div class="tan-exhib-witness-block">
                    <div class="tan-exhib-flavor"><<= setup.Tanning.format_tan_witness_wiki(_w)>></div>
                    <div class="tan-exhib-action">
                        <<set _showlink to setup.Tanning.menu_link_label("show", _w.witness)>>
                        <<link _showlink _tanret>>
                            <<set $tandisplacemsg to setup.Tanning.apply_tease_witness($pc, _w)>>
                            <<lust _w.witness 15 25>>
                            <<raiseskill Exhibitionism 1>>
                            <<advtime _tq Attention>>
                        <</link>> <<dtime _tq>>
                    </div>
                    <div class="tan-exhib-action">
                        <<set _hidelink to setup.Tanning.menu_link_label("hide", _w.witness)>>
                        <<link _hidelink _tanret>>
                            <<set $tandisplacemsg to setup.Tanning.apply_hide_from_witness($pc, _w)>>
                            <<advtime _tq Attention>>
                        <</link>> <<dtime _tq>>
                    </div>
                </div>
            <</capture>>
        <</for>>
    </div>
    <</if>>
    <</if>>
<</widget>>

<<widget "tandexhibflavor">>
    <<if setup.Tanning.can_exhibition_tan($pc)>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<if $tanpose>>
        <br><br>
        <div class="tan-exhib-flavor"><<print setup.Tanning.tan_crowd_narration()>></div>
        <<if setup.Tanning.format_tan_towel_guests()>>
            <br><br>
            <div class="tan-exhib-flavor"><<print setup.Tanning.format_tan_towel_guests()>></div>
        <</if>>
        <<if $tanguestselfmsg>>
            <<for _g range Object.keys($tanguestselfmsg)>>
                <br><br>
                <div class="tan-exhib-flavor"><<= $tanguestselfmsg[_g]>></div>
            <</for>>
            <<unset $tanguestselfmsg>>
        <</if>>
    <</if>>
    <<if $taninvitemsg>>
        <br><br>
        <div class="tan-exhib-flavor"><<= $taninvitemsg>></div>
        <<unset $taninvitemsg>>
    <</if>>
    <<if $tanpassmsg>>
        <br><br>
        <<print $tanpassmsg>>
        <<unset $tanpassmsg>>
    <</if>>
    <<if $tandisplacemsg>>
        <br><br>
        <<= $tandisplacemsg>>
        <<unset $tandisplacemsg>>
    <</if>>
    <<if $tanwitnessextras and $tanwitnessextras.length>>
        <<for _ew range $tanwitnessextras>>
            <br><br>
            <<= setup.Tanning.format_tan_witness_wiki(_ew)>>
        <</for>>
        <<unset $tanwitnessextras>>
    <</if>>
    <<if $tanwitness>>
        <br><br>
        <div class="tan-exhib-flavor"><<= setup.Tanning.format_tan_witness_wiki($tanwitness)>></div>
        <<unset $tanwitness>>
    <</if>>
    <<tandexhibclose>>
    <<set _dispattn to setup.Tanning.attention_from_displacements($pc)>>
    <<set _ambth to setup.Tanning.mall_ambient_attention_threshold()>>
    <<if _dispattn gte _ambth>>
        <br><br>
        <<if _dispattn gte _ambth + 4>>
            The way you've arranged yourself is impossible to ignore. People aren't even pretending not to look.
        <<elseif _dispattn gte _ambth + 2>>
            You catch more than a few lingering stares at how boldly you've shifted your clothes.
        <<else>>
            Someone definitely noticed how you've adjusted your outfit, even if they're trying to be subtle about it.
        <</if>>
    <</if>>
    <<tandexhibaudience>>
    <</if>>
<</widget>>

<<widget "tandexhibaudience">>
    <<if setup.Tanning.can_exhibition_tan($pc) and $tanpose and !setup.Tanning.has_valid_close_escalation()>>
    <<set _targets to setup.Tanning.get_audience_targets($pc)>>
    <<if _targets.length gt 0>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<set _teasereq to setup.Tanning.tease_audience_exhib_req($pc)>>
    <<set _beckonreq to setup.Tanning.beckon_audience_exhib_req($pc)>>
    <div class="tan-exhib-audience">
        <div class="tan-exhib-adjust-title">Invite someone closer</div>
        <div class="tan-exhib-legend">Beckon someone you know (or who's been watching) to your towel. Pleasing/sub inclinations lower the Exhibitionism needed.</div>
        <<for _tgt range _targets>>
            <<capture _tgt,_tanret,_teasereq,_beckonreq>>
                <div class="tan-exhib-action">
                <<if _tgt.canWave>>
                    <<set _wavelink to setup.Tanning.menu_link_label("wave", _tgt.name)>>
                    <<link _wavelink _tanret>>
                        You lift a lazy hand from your towel and wave. <<anonorfullnamerel _tgt.name>> <<conj _tgt.name wave>> back with a <<if setup.people.likes_pc(_tgt.name)>>grin<<else>>small, uncertain smile<</if>>.
                        <<socialize 15>> <<dalterneed Attention 10 true>> <<friendship _tgt.name 10>>
                        <<advtime _tq Attention>>
                    <</link>> <<dtime _tq>>
                <</if>>
                <<if _tgt.canTease>>
                    <<set _teaselink to setup.Tanning.menu_link_label("tease", _tgt.name)>>
                    <<link _teaselink _tanret>>
                        <<set $tandisplacemsg to setup.Tanning.apply_bold_tease_audience($pc, _tgt.name)>>
                        <<lust _tgt.name 12 22>>
                        <<raiseskill Exhibitionism 1>>
                        <<advtime _tq Attention>>
                    <</link>> · Exhib <<print _teasereq>> <<dtime _tq>>
                <<elseif _tgt.familiar>>
                    <span class="disabled-action"><<print setup.Tanning.menu_link_label("tease", _tgt.name)>> · Need Exhib <<print _teasereq>></span>
                <</if>>
                <<if _tgt.canBeckon>>
                    <<set _beckonlink to setup.Tanning.menu_link_label("beckon", _tgt.name)>>
                    <<link _beckonlink _tanret>>
                        <<set $tandisplacemsg to setup.Tanning.apply_beckon_audience($pc, _tgt.name)>>
                        <<lust _tgt.name 22 38>>
                        <<raiseskill Exhibitionism 1>>
                        <<advtime _tq Attention>>
                    <</link>> · Exhib <<print _beckonreq>> <<dtime _tq>>
                <<elseif _tgt.familiar or _tgt.receptive>>
                    <span class="disabled-action"><<print setup.Tanning.menu_link_label("beckon", _tgt.name)>> · Need Exhib <<print _beckonreq>></span>
                <</if>>
                </div>
            <</capture>>
        <</for>>
    </div>
    <</if>>
    <</if>>
<</widget>>

<<widget "tandexhibclose">>
    <<if setup.Tanning.has_valid_close_escalation()>>
    <<if $tanwitnessescalation.finished>>
        <<tandexhibcloseaftermath>>
    <<else>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<set _tp to setup.Tanning.TAN_PLAY_MIN>>
    <<set _p to $tanwitnessescalation.npc>>
    <<set _talkreq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_TALK_EXHIB, $pc)>>
    <<set _teasereq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_BODY_TEASE_EXHIB, $pc)>>
    <<set _touchreq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_SELF_TOUCH_EXHIB, $pc)>>
    <<set _playreq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_SELF_PLAY_EXHIB, $pc)>>
    <<set _showreq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_SHOW_MORE_EXHIB, $pc)>>
    <<set _exposereq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_EXPOSE_EXHIB, $pc)>>
    <<set _fingerreq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_FINGER_EXHIB, $pc)>>
    <<set _orgasmreq to setup.Tanning.close_exhib_req(setup.Tanning.CLOSE_ORGASM_EXHIB, $pc)>>
    <<set _canfinger to setup.Tanning.can_close_finger($pc)>>
    <<set _canorgasm to setup.Tanning.can_close_orgasm($pc)>>
    <<set _hasexpose to setup.Tanning.close_expose_action($pc)>>
    <br><br>
    <div class="tan-exhib-close">
        <<if $tanwitnessescalation.tier is "grope">>
            <<anonorfullname _p>> is far too close — <<ps _p>> <<conj _p watch>> you like <<ps _p>> <<conj _p own>> the view.
        <<else>>
            <<anonorfullname _p>> has settled near your towel, not even pretending <<ps _p>> isn't watching.
        <</if>>
        <<set _npcask to setup.Tanning.maybe_npc_asks_show_more()>>
        <<if _npcask>>
            <br><br>
            <<= _npcask>>
        <</if>>
