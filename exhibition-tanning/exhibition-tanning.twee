<<widget "tandexhibcloseaftermath">>
    <<if setup.Tanning.has_valid_close_escalation() and $tanwitnessescalation.finished>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
    <<set _tp to setup.Tanning.TAN_PLAY_MIN>>
    <<set _p to $tanwitnessescalation.npc>>
    <<set _stance to setup.Tanning.close_npc_stance(_p).stance>>
    <<set _hasmess to setup.Tanning.pc_has_aftermath_mess($pc)>>
    <<set _canhelp to setup.Tanning.can_aftermath_help_npc_finish(_p)>>
    <<set _cancumon to setup.Tanning.can_aftermath_npc_cum_on(_p)>>
    <br><br>
    <div class="tan-exhib-aftermath">
        <span class="small">The show's over — <<anonorfullname _p>> is still right there, taking you in.</span>
        <br><br>
        <span class="bold">Talk</span>
        <br>
        <<capture _tanret,_p,_tq>>
            <<link "\"Did you like watching me?\"" _tanret>>
                <<set _cr to setup.Tanning.apply_aftermath_ask_liked($pc, _p)>>
                <<set $tandisplacemsg to _cr.msg>>
                <<if _cr.arousal>><<dalterneed Arousal _cr.arousal true>><</if>>
                <<lust _p 8 15>>
                <<advtime _tq Attention>>
            <</link>> <<dtime _tq>>
            <br>
            <<link "\"Thank you for watching.\" — fix up and leave" _tanret>>
                <<set _cr to setup.Tanning.apply_aftermath_thank_leave($pc, _p)>>
                <<set $tandisplacemsg to _cr.msg>>
                <<lust _p 5 10>>
                <<advtime _tq Composure>>
            <</link>> <<dtime _tq>>
            <br>
            <<link "\"Okay, I have to go.\" — fix up and leave <<po _p>> hanging" _tanret>>
                <<set _cr to setup.Tanning.apply_aftermath_abrupt_leave($pc, _p)>>
                <<set $tandisplacemsg to _cr.msg>>
                <<if _cr.humiliation>><<dalterneed Humiliation _cr.humiliation true>><</if>>
                <<advtime _tq>>
            <</link>> <<dtime _tq>>
            <br>
            <<if _stance is "lover">>
                <<link "\"Want to do that again sometime?\"" _tanret>>
                    <<set _cr to setup.Tanning.apply_aftermath_ask_again($pc, _p)>>
                    <<set $tandisplacemsg to _cr.msg>>
                    <<if _cr.arousal>><<dalterneed Arousal _cr.arousal true>><</if>>
                    <<lust _p 12 22>> <<romance _p 15>>
                    <<advtime _tq Attention>>
                <</link>> <<dtime _tq>>
                <br>
            <</if>>
            <<if _stance is "bully" or _stance is "enemy" or _stance is "rival">>
                <<link "\"Going to tell anyone about this?\"" _tanret>>
                    <<set _cr to setup.Tanning.apply_aftermath_ask_tell_anyone($pc, _p)>>
                    <<set $tandisplacemsg to _cr.msg>>
                    <<lust _p 10 18>>
                    <<advtime _tq Attention>>
                <</link>> <<dtime _tq>>
                <br>
            <</if>>
        <</capture>>
        <br>
        <span class="bold">Actions</span>
        <br>
        <<capture _tanret,_p,_hasmess,_canhelp,_cancumon,_tq,_tp>>
            <<link "Fix your clothes and leave without a word" _tanret>>
                <<set _cr to setup.Tanning.apply_aftermath_silent_leave($pc, _p)>>
                <<set $tandisplacemsg to _cr.msg>>
                <<if _cr.humiliation>><<dalterneed Humiliation _cr.humiliation true>><</if>>
                <<advtime _tq Composure>>
            <</link>> <<dtime _tq>>
            <br>
            <<if _hasmess>>
                <<link "Hold your hand out so <<ps _p>> can wipe you clean" _tanret>>
                    <<set _cr to setup.Tanning.apply_aftermath_offer_hand_clean($pc, _p)>>
                    <<set $tandisplacemsg to _cr.msg>>
                    <<if _cr.arousal>><<dalterneed Arousal _cr.arousal true>><</if>>
                    <<lust _p 15 28>>
                    <<advtime _tq Attention>>
                <</link>> <<dtime _tq>>
                <br>
                <<link "Beckon <<po _p>> to lick you clean" _tanret>>
                    <<set _cr to setup.Tanning.apply_aftermath_lick_clean($pc, _p)>>
                    <<set $tandisplacemsg to _cr.msg>>
                    <<if _cr.arousal>><<dalterneed Arousal _cr.arousal true>><</if>>
                    <<if _cr.humiliation>><<dalterneed Humiliation _cr.humiliation true>><</if>>
                    <<lust _p 25 42>>
                    <<raiseskill Exhibitionism 1>>
                    <<advtime _tp Attention>>
                <</link>> <<dtime _tp>>
                <br>
            <</if>>
            <<if _canhelp>>
                <<link "Help <<po _p>> finish too" _tanret>>
                    <<set _cr to setup.Tanning.apply_aftermath_help_npc_finish($pc, _p)>>
                    <<set $tandisplacemsg to _cr.msg>>
                    <<if _cr.arousal>><<dalterneed Arousal _cr.arousal true>><</if>>
                    <<if _cr.attention>><<dalterneed Attention _cr.attention true>><</if>>
                    <<lust _p 35 55>>
                    <<advtime _tp Attention>>
                <</link>> <<dtime _tp>>
                <br>
            <</if>>
            <<if _cancumon>>
                <<tandexhibcumonmenu>>
            <</if>>
            <<tandexhibcrossoveraftermath>>
        <</capture>>
        <br>
        <span class="bold">Send <<po _p>> away</span>
        <br>
        <<capture _tanret,_p,_tq>>
            <<link "That was fun — now shoo, you want more visitors" _tanret>>
                <<set _cr to setup.Tanning.apply_aftermath_shoo_nice($pc, _p)>>
                <<set $tandisplacemsg to _cr.msg>>
                <<if _cr.attention>><<dalterneed Attention _cr.attention true>><</if>>
                <<lust _p 5 12>>
                <<advtime _tq Attention>>
            <</link>> <<dtime _tq>>
            <br>
        <</capture>>
    </div>
    <</if>>
<</widget>>

<<widget "tandexhibcrossoveractions">>
    <<set _sub to _args[0] || $tancrossoverexpanded>>
    <<set _w to _args[1] || $tanwitnessescalation.npc>>
    <<set _tanret to setup.Tanning.get_tan_passage()>>
    <<set _tq to setup.Tanning.TAN_QUICK_MIN>>
